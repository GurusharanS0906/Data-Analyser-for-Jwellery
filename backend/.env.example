ENVIRONMENT=development
DEBUG=true

# Comma-separated list is not needed — edit CORS_ORIGINS in app/core/config.py
# defaults, or override via JSON list if you wire up env parsing later.

# Must match frontend's BACKEND_JWT_SECRET
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256

DATABASE_URL=postgresql://jewelai:jewelai_dev_password@localhost:5433/jewelai?schema=public
REDIS_URL=redis://localhost:6380

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

MAX_UPLOAD_SIZE_MB=100
RATE_LIMIT_PER_MINUTE=60
