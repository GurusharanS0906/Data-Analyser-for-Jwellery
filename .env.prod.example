# Production full-stack compose config.
# Copy to .env.prod and fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Postgres ---
POSTGRES_USER=jewelai
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=jewelai

# --- Connection strings (services reach Postgres/Redis by their compose name) ---
DATABASE_URL=postgresql://jewelai:change-me-strong-password@postgres:5432/jewelai?schema=public
REDIS_URL=redis://redis:6379

# --- Auth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret for the browser→backend bridge tokens (upload/chat/report).
# The frontend signs with it, the backend validates with it — they MUST match.
BACKEND_JWT_SECRET=generate-another-openssl-rand-base64-32

# --- Public backend URL (baked into the frontend bundle at build time) ---
# For local docker this is the host-published backend port. In real deployment
# set it to the backend's public HTTPS URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend CORS: the frontend's public origin (comma-separated for multiple) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- AI (leave ANTHROPIC_API_KEY blank to run everything except live AI Chat) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
