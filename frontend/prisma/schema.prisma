// Jewellery AI Analytics — Prisma schema
// Auth, uploads, and AI chat metadata live here (PostgreSQL).
// Heavy analytical processing (Pandas/DuckDB) happens in the FastAPI backend.

generator client {
  provider = "prisma-client-js"
  // Native = local dev; the debian target matches the bookworm-slim Docker image.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth-compatible schema)
// ---------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(OWNER)
  companyName   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  uploadedFiles    UploadedFile[]
  chatSessions     ChatSession[]
  savedQuestions   SavedQuestion[]
  reports          Report[]
  companySettings  CompanySettings?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Uploads
// ---------------------------------------------------------------------------

enum UploadStatus {
  UPLOADED
  CLEANING
  PROCESSING
  READY
  FAILED
}

model UploadedFile {
  id           String       @id @default(cuid())
  userId       String
  fileName     String
  originalName String
  fileSizeKb   Int
  fileType     String
  storagePath  String
  rowCount     Int?
  columnCount  Int?
  status       UploadStatus @default(UPLOADED)
  cleaningLog  Json?
  errorMessage String?
  uploadedAt   DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessions ChatSession[]
  reports      Report[]

  @@index([userId])
  @@map("uploaded_files")
}

// ---------------------------------------------------------------------------
// AI Chat
// ---------------------------------------------------------------------------

enum MessageRole {
  USER
  ASSISTANT
}

model ChatSession {
  id             String   @id @default(cuid())
  userId         String
  uploadedFileId String?
  title          String   @default("New Conversation")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String      @db.Text
  sqlQuery      String?     @db.Text
  chartConfig   Json?
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@map("chat_messages")
}

model SavedQuestion {
  id        String   @id @default(cuid())
  userId    String
  question  String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_questions")
}

// ---------------------------------------------------------------------------
// Reports
// ---------------------------------------------------------------------------

enum ReportType {
  PDF
  EXCEL
  CSV
}

model Report {
  id             String     @id @default(cuid())
  userId         String
  uploadedFileId String?
  title          String
  type           ReportType
  filePath       String
  createdAt      DateTime   @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("reports")
}

// ---------------------------------------------------------------------------
// Settings
// ---------------------------------------------------------------------------

model CompanySettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  logoUrl     String?
  currency    String   @default("INR")
  language    String   @default("en")
  theme       String   @default("dark")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}
